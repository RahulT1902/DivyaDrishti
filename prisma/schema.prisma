generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(uuid())
  name               String
  email              String               @unique
  passwordHash       String?
  reputationScore    Float                @default(50.0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  lastDecisionSignal String?
  lastIntent         String?
  lastTimeframe      String?
  lastViewedAt       DateTime?
  streakCount        Int                  @default(0)
  accountability     AccountabilityNode[]
  actions            ActionUnit[]
  birthDetails       BirthDetails?
  portfolios         LifePortfolio[]
  predictions        PredictionRecord[]
}

model BirthDetails {
  id          String   @id @default(uuid())
  userId      String   @unique
  dateOfBirth DateTime
  timeOfBirth String
  latitude    Float
  longitude   Float
  timezone    String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PredictionRecord {
  id                String   @id @default(uuid())
  userId            String
  type              String
  domain            String
  prediction        String
  predictionScore   Float
  accuracyPredicted Float
  confidence        Float
  risk              Float
  startTime         DateTime
  endTime           DateTime
  outcome           String?
  outcomeScore      Float?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActionUnit {
  id                   String   @id @default(uuid())
  userId               String
  domain               String
  task                 String
  priority             String
  energyRequired       String
  timingWindowStart    DateTime
  timingWindowEnd      DateTime
  probabilityOfSuccess Float
  completed            Boolean  @default(false)
  completionQuality    Int?
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LifePortfolio {
  id                String   @id @default(uuid())
  userId            String
  mode              String
  careerAlloc       Float
  financeAlloc      Float
  healthAlloc       Float
  relationshipAlloc Float
  growthAlloc       Float
  careerRisk        Float
  financeRisk       Float
  healthRisk        Float
  relationshipRisk  Float
  growthRisk        Float
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AccountabilityNode {
  id                  String   @id @default(uuid())
  userId              String
  partnerId           String?
  relationshipType    String
  accountabilityLevel String
  stakeAmount         Float?
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
