generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(uuid())
  name               String
  email              String               @unique
  passwordHash       String?
  reputationScore    Float                @default(50.0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // Relations
  profile            UserProfile?
  birthChart         BirthChart?
  goals              UserGoal[]
  habits             HabitTracking[]
  timelineWindows    TimelineWindow[]
  dailyInsights      DailyInsight[]
  memories           UserMemory[]
  reflections        DailyReflection[]
  lifeInsightFeedbacks          LifeInsightFeedback[]
  lifeInsightAnalytics          LifeInsightAnalytics[]
  lifeInsightPredictionJournals LifeInsightPredictionJournal[]
  consultationMemory ConsultationMemory[]

  // Legacy/Internal (Keeping for migration safety)
  birthDetails       BirthDetails?
  portfolios         LifePortfolio[]
  predictions        PredictionRecord[]
  accountability     AccountabilityNode[]
  actions            ActionUnit[]
}

// Stores the last known domain assessment per user across sessions.
// When a new session starts the Pundit already knows the person's
// active domain state without them having to re-establish context.
model ConsultationMemory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  domain       String   // "career" | "health" | "finance" | "relationship"

  state        String?  // "Favorable" | "Moderate" | "Challenging" etc.
  overallLine  String?  // The "Overall: ..." sentence from the last response
  whySentence  String?  // The "Why today/this period?" sentence
  situation    String?  // Career: "Promotion Window", "Building Phase", etc.

  // Dasha snapshot — used to detect stale memory when period changes
  mahadasha    String?
  antardasha   String?
  dashaEndDate String?  // ISO date; memory is stale if this is in the past

  topics       Json?    // string[] — sub-topics discussed: ["promotion", "management"]

  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([userId, domain])
  @@index([userId])
}

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName       String?
  timezone          String?
  language          String?

  onboardingDone    Boolean  @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model BirthChart {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  birthDate          DateTime
  birthTime          String
  birthPlace         String

  latitude           Float
  longitude          Float

  ayanamsa           String?

  chartData          Json     // Cached computed chart - DO NOT recompute every request

  createdAt          DateTime @default(now())
}

model UserGoal {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  category            GoalCategory
  title               String
  description         String?

  priority            Int      @default(3)
  targetDate          DateTime?

  currentStatus       GoalStatus @default(ACTIVE)

  emotionalImportance Int?     // 1-10 scale
  metadata            Json?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

enum GoalCategory {
  CAREER
  BUSINESS
  FINANCE
  RELATIONSHIP
  HEALTH
  SPIRITUALITY
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

model HabitTracking {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title              String
  category           HabitCategory
  
  streak             Int      @default(0)
  consistencyScore   Float    @default(0)
  
  aiGenerated        Boolean  @default(false)
  active             Boolean  @default(true)

  createdAt          DateTime @default(now())
}

enum HabitCategory {
  DISCIPLINE
  MEDITATION
  HEALTH
  LEARNING
  SOCIAL
}

model TimelineWindow {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  startDate           DateTime
  endDate             DateTime

  category            TimelineCategory
  intensityScore      Float    // 0-10

  summary             String
  
  opportunities       Json     // List of potential wins
  cautions            Json     // List of risks
  recommendations     Json     // Action steps

  generatedBy         String?  // Agent name

  createdAt           DateTime @default(now())
}

enum TimelineCategory {
  GROWTH
  CAUTION
  TRANSFORMATION
  VOLATILITY
  PRODUCTIVITY
}

model DailyInsight {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date               DateTime
  summary            String

  favorable          Json
  cautions           Json
  focusAreas         Json

  emotionalTone      String?

  generatedAt        DateTime @default(now())
}

model UserMemory {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  memoryType         MemoryType
  content            String

  embedding          Unsupported("vector")? // Vector for semantic search

  importance         Float    @default(0.5)

  createdAt          DateTime @default(now())
}

enum MemoryType {
  PREFERENCE
  FEAR
  AMBITION
  OBSERVATION
  CONTEXT
}

// Legacy Models (Retained for migration context)

model DailyReflection {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  date        DateTime    // Truncated to midnight UTC
  energy      EnergyLevel
  stress      StressLevel
  notes       String?     @db.Text
  source      String?     // e.g., "MANUAL" or "AUTO_IMPORT"
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@unique([userId, date])
}

enum EnergyLevel {
  HIGH
  NEUTRAL
  LOW
}

enum StressLevel {
  LOW
  MEDIUM
  HIGH
}

model BirthDetails {
  id          String   @id @default(uuid())
  userId      String   @unique
  dateOfBirth DateTime
  timeOfBirth String
  latitude    Float
  longitude   Float
  timezone    String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PredictionRecord {
  id                String   @id @default(uuid())
  userId            String
  type              String
  domain            String
  prediction        String
  predictionScore   Float
  accuracyPredicted Float
  confidence        Float
  risk              Float
  startTime         DateTime
  endTime           DateTime
  outcome           String?
  outcomeScore      Float?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActionUnit {
  id                   String   @id @default(uuid())
  userId               String
  domain               String
  task                 String
  priority             String
  energyRequired       String
  timingWindowStart    DateTime
  timingWindowEnd      DateTime
  probabilityOfSuccess Float
  completed            Boolean  @default(false)
  completionQuality    Int?
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LifePortfolio {
  id                String   @id @default(uuid())
  userId            String
  mode              String
  careerAlloc       Float
  financeAlloc      Float
  healthAlloc       Float
  relationshipAlloc Float
  growthAlloc       Float
  careerRisk        Float
  financeRisk       Float
  healthRisk        Float
  relationshipRisk  Float
  growthRisk        Float
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AccountabilityNode {
  id                  String   @id @default(uuid())
  userId              String
  partnerId           String?
  relationshipType    String
  accountabilityLevel String
  stakeAmount         Float?
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LifeInsightFeedback {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodStart       DateTime
  periodEnd         DateTime
  theme             String
  eventName         String
  feedback          String   // "HAPPENED" | "PARTIALLY_HAPPENED" | "DID_NOT_HAPPEN" | "NOT_SURE"
  predictionVersion String   @default("2.0")
  createdAt         DateTime @default(now())

  @@index([userId])
}

model LifeInsightAnalytics {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType         String   // "PAGE_VISIT" | "VIEW_CATEGORY" | "FEEDBACK_SUBMIT" | "ENGAGEMENT"
  category          String?  // "career" | "finance" | "relationships" | "health" | "priority"
  engagementTimeMs  Int?
  metadata          Json?
  predictionVersion String   @default("2.0")
  createdAt         DateTime @default(now())

  @@index([userId])
}

model LifeInsightPredictionJournal {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                 String
  domain                String   // "career" | "finance" | "relationships" | "health"
  predictionText        String
  targetMonth           String   // e.g. "September 2026"
  status                String   // "UPCOMING" | "HAPPENED" | "PARTIALLY_HAPPENED" | "DID_NOT_HAPPEN"
  confidenceScore       Int      // 0-100
  confidenceContributors Json     // Contributors list with weights
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}
